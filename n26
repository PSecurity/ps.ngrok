#!/bin/bash
# =====================================
# PeekSecurity Installer Ngrok
# =====================================

# ====== CORES ======
verde="\e[32m"
vermelho="\e[31m"
amarelo="\e[33m"
azul="\e[34m"
reset="\e[0m"

# ====== BANNER ======
clear
echo -e "${azul}"
echo "====================================="
echo "   PeekSecurity Smart Installer"
echo "====================================="
echo -e "${reset}"

# ====== DETECÇÃO AMBIENTE ======
detectar_ambiente() {
    if [[ -d "/data/data/com.termux" ]]; then
        echo "termux"
    elif grep -qi "kali" /etc/os-release 2>/dev/null; then
        echo "kali"
    else
        echo "desconhecido"
    fi
}

ambiente=$(detectar_ambiente)

echo -e "${amarelo}Ambiente: ${verde}$ambiente${reset}"

# ====== LOADING ======
loading() {
    echo -ne "${amarelo}Processando"
    for i in {1..3}; do
        echo -ne "."
        sleep 0.4
    done
    echo -e "${reset}"
}

# ====== DETECTAR ARCH ======
detectar_arch() {
    ARCH=$(uname -m)

    case "$ARCH" in
        x86_64)
            NGROK_URL="https://bin.equinox.io/c/bNyj1mQVY4c/ngrok-v3-stable-linux-amd64.tgz"
            CLOUDFLARE_URL="https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-amd64"
            ;;
        aarch64)
            NGROK_URL="https://bin.equinox.io/c/bNyj1mQVY4c/ngrok-v3-stable-linux-arm64.tgz"
            CLOUDFLARE_URL="https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-arm64"
            ;;
        armv7l)
            NGROK_URL="https://bin.equinox.io/c/bNyj1mQVY4c/ngrok-v3-stable-linux-arm.tgz"
            CLOUDFLARE_URL="https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-arm"
            ;;
        i686)
            echo -e "${amarelo}32 bits detectado → Ngrok não suportado${reset}"
            NGROK_URL=""
            CLOUDFLARE_URL="https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-386"
            ;;
        *)
            echo -e "${vermelho}Arquitetura não suportada: $ARCH${reset}"
            exit 1
            ;;
    esac
}

# ====== VERIFICAR NGROK ======
verificar_ngrok() {
    if command -v ngrok >/dev/null 2>&1; then
        if ngrok version >/dev/null 2>&1; then
            echo -e "${verde}✔ Ngrok funcional${reset}"
            return 0
        else
            echo -e "${vermelho}Ngrok quebrado! Reinstalando...${reset}"

            if [[ "$ambiente" == "kali" ]]; then
                sudo rm -f /usr/local/bin/ngrok
            else
                rm -f $PREFIX/bin/ngrok
            fi

            return 1
        fi
    else
        return 1
    fi
}

# ====== INSTALAR NGROK ======
instalar_ngrok() {

    detectar_arch

    if [[ -z "$NGROK_URL" ]]; then
        echo -e "${vermelho}Ngrok não disponível para essa arquitetura${reset}"
        return
    fi

    verificar_ngrok && return

    echo -e "${amarelo}Baixando ngrok...${reset}"

    wget -O ngrok.tgz "$NGROK_URL" || exit 1
    tar -xzf ngrok.tgz || exit 1

    chmod +x ngrok

    if [[ "$ambiente" == "kali" ]]; then
        sudo mv ngrok /usr/local/bin/
    else
        mv ngrok $PREFIX/bin/
    fi

    ngrok version >/dev/null 2>&1 && \
    echo -e "${verde}✔ Ngrok instalado!${reset}" || \
    echo -e "${vermelho}Erro no ngrok${reset}"
}

# ====== INSTALAR CLOUDFLARE ======
instalar_cloudflare() {

    detectar_arch

    echo -e "${amarelo}Baixando Cloudflare Tunnel...${reset}"

    wget -O cloudflared "$CLOUDFLARE_URL" || exit 1
    chmod +x cloudflared

    if [[ "$ambiente" == "kali" ]]; then
        sudo mv cloudflared /usr/local/bin/
    else
        mv cloudflared $PREFIX/bin/
    fi

    cloudflared --version >/dev/null 2>&1 && \
    echo -e "${verde}✔ Cloudflare instalado!${reset}" || \
    echo -e "${vermelho}Erro no Cloudflare${reset}"
}

# ====== CONFIG TOKEN ======
configurar_token() {
    read -p "Configurar authtoken do ngrok? (s/n): " resp

    if [[ "$resp" =~ ^[sS]$ ]]; then
        read -p "Token: " token

        ngrok config add-authtoken "$token" && \
        echo -e "${verde}✔ Token OK${reset}" || \
        echo -e "${vermelho}Erro no token${reset}"
    fi
}

# ====== DEPENDÊNCIAS ======
case $ambiente in
    termux)
        loading
        pkg update -y && pkg install wget tar -y
        ;;
    kali)
        loading
        sudo apt update && sudo apt install wget tar -y
        ;;
    *)
        echo "Ambiente não suportado"
        exit 1
        ;;
esac

# ====== MENU FINAL ======
echo ""
echo -e "${azul}Escolha o túnel:${reset}"
echo "1) Ngrok"
echo "2) Cloudflare (Recomendado)"
echo ""
read -p "Opção: " escolha

case $escolha in
    1)
        instalar_ngrok
        configurar_token
        ;;
    2)
        instalar_cloudflare
        ;;
    *)
        echo -e "${vermelho}Opção inválida${reset}"
        exit 1
        ;;
esac

# ====== FINAL ======
echo ""
echo -e "${verde}✔ Instalação concluída!${reset}"
echo -e "${azul}Teste:${reset}"
echo "ngrok version"
echo "cloudflared --version"
