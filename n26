#!/bin/bash
# =====================================
# PeekSecurity Installer
# by PeekSecurity
# =====================================

# ====== CORES ======
verde="\e[32m"
vermelho="\e[31m"
amarelo="\e[33m"
azul="\e[34m"
reset="\e[0m"

# ====== BANNER ======
clear
echo -e "${azul}"
echo "====================================="
echo "      PeekSecurity Installer"
echo "-------------------------------------"
echo "   by PeekSecurity • @peeksecurity"
echo "====================================="
echo -e "${reset}"

# ====== DETECÇÃO AUTOMÁTICA ======
detectar_ambiente() {
    if [[ -d "/data/data/com.termux" ]]; then
        echo "termux"
    elif grep -qi "kali" /etc/os-release 2>/dev/null; then
        echo "kali"
    else
        echo "desconhecido"
    fi
}

ambiente_detectado=$(detectar_ambiente)

echo -e "${amarelo}Ambiente detectado: ${verde}$ambiente_detectado${reset}"
echo ""

# ====== MENU ======
echo -e "${azul}Selecione uma opção:${reset}"
echo "1) Usar ambiente detectado"
echo "2) Escolher manualmente"
echo ""
read -p "Opção: " escolha

if [[ "$escolha" == "1" ]]; then
    ambiente="$ambiente_detectado"
else
    read -p "Digite o ambiente (termux/kali): " ambiente
    ambiente=$(echo "$ambiente" | tr '[:upper:]' '[:lower:]')
fi

# ====== LOADING ======
loading() {
    echo -ne "${amarelo}Processando"
    for i in {1..3}; do
        echo -ne "."
        sleep 0.5
    done
    echo -e "${reset}"
}

# ====== DETECTAR ARQUITETURA ======
detectar_arch() {
    ARCH=$(uname -m)

    case "$ARCH" in
        x86_64)
            NGROK_URL="https://bin.equinox.io/c/bNyj1mQVY4c/ngrok-v3-stable-linux-amd64.tgz"
            ;;
        aarch64)
            NGROK_URL="https://bin.equinox.io/c/bNyj1mQVY4c/ngrok-v3-stable-linux-arm64.tgz"
            ;;
        armv7l)
            NGROK_URL="https://bin.equinox.io/c/bNyj1mQVY4c/ngrok-v3-stable-linux-arm.tgz"
            ;;
        *)
            echo -e "${vermelho}Arquitetura não suportada: $ARCH${reset}"
            exit 1
            ;;
    esac
}

# ====== INSTALAR NGROK ======
instalar_ngrok() {

    if command -v ngrok >/dev/null 2>&1; then
        echo -e "${amarelo}Ngrok já está instalado.${reset}"
        return
    fi

    detectar_arch

    echo -e "${amarelo}Arquitetura detectada: $ARCH${reset}"
    echo -e "${amarelo}Baixando ngrok...${reset}"

    wget -O ngrok.tgz "$NGROK_URL" || {
        echo -e "${vermelho}Erro ao baixar o ngrok.${reset}"
        exit 1
    }

    echo -e "${amarelo}Extraindo ngrok...${reset}"
    tar -xzf ngrok.tgz || {
        echo -e "${vermelho}Erro ao extrair o ngrok.${reset}"
        exit 1
    }

    chmod +x ngrok

    if [[ "$ambiente" == "termux" ]]; then
        mv ngrok $PREFIX/bin/
    elif [[ "$ambiente" == "kali" ]]; then
        sudo mv ngrok /usr/local/bin/
    fi

    # TESTE REAL
    if ! command -v ngrok >/dev/null 2>&1; then
        echo -e "${vermelho}Ngrok não foi instalado corretamente.${reset}"
        exit 1
    fi

    echo -e "${verde}✔ Ngrok instalado com sucesso!${reset}"
}

# ====== CONFIG TOKEN ======
configurar_token() {
    echo ""
    read -p "Deseja configurar o authtoken do ngrok agora? (s/n): " resp

    if [[ "$resp" =~ ^[sS]$ ]]; then
        read -p "Cole seu authtoken do ngrok: " token

        if [[ -n "$token" ]]; then

            if ! command -v ngrok >/dev/null 2>&1; then
                echo -e "${vermelho}Ngrok não está funcionando.${reset}"
                return
            fi

            ngrok config add-authtoken "$token"

            if [[ $? -eq 0 ]]; then
                echo -e "${verde}✔ Token configurado com sucesso!${reset}"
            else
                echo -e "${vermelho}Erro ao configurar o token.${reset}"
            fi
        else
            echo -e "${vermelho}Token vazio!${reset}"
        fi
    else
        echo -e "${amarelo}Configuração ignorada.${reset}"
    fi
}

# ====== EXECUÇÃO ======
case $ambiente in

    termux)
        echo -e "${verde}Instalando no Termux...${reset}"
        loading

        pkg update -y && pkg upgrade -y
        pkg install git wget tar -y

        instalar_ngrok
        configurar_token
        ;;

    kali)
        echo -e "${verde}Instalando no Kali Linux...${reset}"
        loading

        sudo apt update && sudo apt upgrade -y
        sudo apt install git wget tar -y

        instalar_ngrok
        configurar_token
        ;;

    *)
        echo -e "${vermelho}Ambiente inválido!${reset}"
        exit 1
        ;;
esac

# ====== FINAL ======
echo ""
echo -e "${verde}✔ Instalação finalizada com sucesso!${reset}"
echo -e "${azul}Teste com: ngrok version${reset}"
